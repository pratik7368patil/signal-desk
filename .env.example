# Optional fallback. Prefer `sig slack login` to create this locally.
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# Optional fallback for Post as Me / personal Slack context. Prefer OAuth storage.
# SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_CLIENT_ID=123456789.123456789
SLACK_CLIENT_SECRET=your-slack-client-secret
SIGNALD_CONFIG=assistant.config.yaml
SIGNALD_DB_PATH=.signald.sqlite
SIGNALD_LOG_LEVEL=info
